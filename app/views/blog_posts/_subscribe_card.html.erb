<% turnstile_site_key = if ENV["CLOUDFLARE_TURNSTILE_SITEKEY"].present? && ENV["CLOUDFLARE_TURNSTILE_SECRET_KEY"].present?
     ENV["CLOUDFLARE_TURNSTILE_SITEKEY"]
   end %>

<%= turbo_mount(
  "blog/BlogSubscribeForm",
  props: {
    createPath: api_v1_blog_subscriptions_path,
    title: t("blog_subscriptions.card.title"),
    description: t("blog_subscriptions.card.description"),
    emailLabel: t("blog_subscriptions.card.email_label"),
    emailPlaceholder: t("blog_subscriptions.card.email_placeholder"),
    submitLabel: t("blog_subscriptions.card.submit_label"),
    successMessage: t("blog_subscriptions.card.success_message"),
    subscribedTitle: t("blog_subscriptions.card.subscribed_title"),
    subscribedDescription: t("blog_subscriptions.card.subscribed_description"),
    resetLabel: t("blog_subscriptions.card.reset_label"),
    turnstileSiteKey: turnstile_site_key,
    verificationRequiredMessage: t("blog_subscriptions.card.verification_required"),
    unavailableMessage: t("blog_subscriptions.card.unavailable")
  }
) %>
