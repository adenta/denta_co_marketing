<% content_for :title, "#{@post.title} | Andrew Denta" %>
<% provide :meta_description, @post.excerpt %>
<% content_for :head do %>
  <%= stylesheet_link_tag "blog", "data-turbo-track": "reload" %>
<% end %>

<section class="blog-grid-shell border-b border-[#237671]/10 dark:border-[#89dcd7]/14">
  <div aria-hidden="true" class="blog-square-cluster blog-square-cluster--top-left">
    <span></span>
    <span></span>
  </div>
  <div aria-hidden="true" class="blog-square-cluster blog-square-cluster--top-right">
    <span></span>
    <span></span>
  </div>

  <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6 sm:py-20 lg:px-8">
    <div class="max-w-3xl space-y-5">
      <%= link_to "Back to writing", blog_posts_path, class: "inline-flex rounded-full border border-[#237671]/12 bg-white px-3 py-2 text-sm font-medium text-[#355350] transition-colors hover:border-[#237671]/28 hover:text-[#0c2726] dark:border-[#89dcd7]/14 dark:bg-[#1a1a19]/88 dark:text-[#b5b5b0] dark:hover:border-[#89dcd7]/30 dark:hover:text-[#f3f3f2]" %>

      <div class="flex flex-wrap items-center gap-3 text-sm text-muted-foreground">
        <time datetime="<%= @post.published_on.iso8601 %>"><%= @post.published_on.to_fs(:long) %></time>
        <span>&middot;</span>
        <span><%= @post.author %></span>
        <% if @post.draft? %>
          <span>&middot;</span>
          <span class="rounded-full bg-amber-100 px-2.5 py-1 text-xs font-semibold tracking-[0.14em] text-amber-900 uppercase dark:bg-amber-500/20 dark:text-amber-200">Draft preview</span>
        <% end %>
      </div>

      <h1 class="text-4xl font-semibold tracking-tight text-foreground sm:text-5xl"><%= @post.title %></h1>
      <p class="text-lg leading-8 text-[#4f5b57] dark:text-[#b5b5b0]"><%= @post.excerpt %></p>
    </div>
  </div>
</section>

<section class="mx-auto max-w-3xl px-4 py-12 sm:px-6 lg:px-8">
  <article class="blog-prose">
    <%= @post.html_body.html_safe %>
  </article>

  <div class="mt-10">
    <%= render "subscribe_card" %>
  </div>
</section>
