<% content_for :title, "#{@post.title} | Andrew Denta" %>
<% provide :meta_description, @post.excerpt %>
<% content_for :head do %>
  <%= stylesheet_link_tag "blog", "data-turbo-track": "reload" %>
<% end %>

<section class="mx-auto max-w-3xl px-4 py-8 sm:px-6 sm:py-10 lg:px-8">
  <div class="blog-post-hero-simple mb-8 sm:mb-10">
    <%= link_to "← All posts", blog_posts_path, class: "blog-post-hero-simple__back" %>

    <div class="blog-post-hero-simple__title-block">
      <h1 class="text-[2.7rem] font-semibold tracking-tight text-foreground sm:text-[3.1rem] sm:leading-[1.04]"><%= @post.title %></h1>
      <div class="blog-post-hero-simple__subline">
        <time datetime="<%= @post.published_on.iso8601 %>"><%= @post.published_on.to_fs(:long) %></time>
        <% if @post.draft? %>
          <span class="blog-post-hero-simple__subline-separator">•</span>
          <span class="text-amber-900 dark:text-amber-200">Draft preview</span>
        <% end %>
      </div>
      <p class="text-[1rem] leading-7 text-[#475569] dark:text-[#9eabb8]"><%= @post.excerpt %></p>
    </div>
  </div>

  <article class="blog-prose">
    <%= @post.html_body.html_safe %>
  </article>

  <div class="mt-8">
    <%= render "subscribe_card" %>
  </div>
</section>
