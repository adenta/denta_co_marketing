<% content_for :title, "#{@post.title} | Denta Co Marketing" %>
<% provide :meta_description, @post.excerpt %>
<% content_for :head do %>
  <%= stylesheet_link_tag "blog", "data-turbo-track": "reload" %>
<% end %>

<section class="border-b border-border/70 bg-linear-to-b from-slate-50 to-background">
  <div class="mx-auto max-w-6xl px-4 py-14 sm:px-6 lg:px-8">
    <div class="max-w-3xl space-y-5">
      <%= link_to "Back to blog", blog_posts_path, class: "inline-flex text-sm font-medium text-muted-foreground transition-colors hover:text-foreground" %>

      <div class="flex flex-wrap items-center gap-3 text-sm text-muted-foreground">
        <time datetime="<%= @post.published_on.iso8601 %>"><%= @post.published_on.to_fs(:long) %></time>
        <span>&middot;</span>
        <span><%= @post.author %></span>
        <span>&middot;</span>
        <span><%= pluralize(@post.reading_time_minutes, "minute") %> read</span>
        <% if @post.draft? %>
          <span class="rounded-full bg-amber-100 px-2.5 py-1 text-xs font-semibold tracking-[0.14em] text-amber-900 uppercase">Draft preview</span>
        <% end %>
      </div>

      <h1 class="text-4xl font-semibold tracking-tight text-foreground sm:text-5xl"><%= @post.title %></h1>
      <p class="text-lg leading-8 text-muted-foreground"><%= @post.excerpt %></p>

      <% if @post.tags.any? %>
        <div class="flex flex-wrap gap-2 pt-2">
          <% @post.tags.each do |tag| %>
            <span class="rounded-full border border-border bg-background px-3 py-1 text-xs font-medium tracking-[0.12em] text-muted-foreground uppercase"><%= tag %></span>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
</section>

<section class="mx-auto grid max-w-6xl gap-10 px-4 py-12 sm:px-6 lg:grid-cols-[minmax(0,1fr)_20rem] lg:px-8">
  <div class="min-w-0">
    <% if @post.cover_image.present? %>
      <figure class="mb-8 overflow-hidden rounded-3xl border border-border/70 bg-card shadow-sm shadow-black/5">
        <img src="<%= @post.cover_image %>" alt="<%= @post.title %>" class="h-auto w-full object-cover">
      </figure>
    <% end %>

    <article class="blog-prose">
      <%= @post.html_body.html_safe %>
    </article>
  </div>

  <aside class="space-y-6">
    <%= turbo_mount("blog/PostEnhancements", props: { headings: @post.headings, title: @post.title }) %>

    <% if @related_posts.any? %>
      <section class="rounded-3xl border border-border/70 bg-card/80 p-5 shadow-sm shadow-black/5">
        <p class="text-sm font-semibold tracking-[0.2em] text-muted-foreground uppercase">Related posts</p>
        <div class="mt-4 space-y-4">
          <% @related_posts.each do |post| %>
            <article class="space-y-1">
              <h2 class="text-base font-medium tracking-tight text-foreground">
                <%= link_to post.title, blog_post_path(post.slug), class: "hover:text-primary" %>
              </h2>
              <p class="text-sm leading-6 text-muted-foreground"><%= post.excerpt %></p>
            </article>
          <% end %>
        </div>
      </section>
    <% end %>
  </aside>
</section>
