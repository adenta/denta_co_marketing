<article class="blog-surface-card rounded-[1.3rem] p-5">
  <div class="flex flex-wrap items-center gap-3 text-sm text-muted-foreground">
    <time datetime="<%= post.published_on.iso8601 %>"><%= post.published_on.to_fs(:long) %></time>
    <% if post.draft? %>
      <span>&middot;</span>
      <span class="rounded-full bg-amber-100 px-2.5 py-1 text-xs font-semibold tracking-[0.14em] text-amber-900 uppercase dark:bg-amber-500/20 dark:text-amber-200">Draft</span>
    <% end %>
  </div>

  <div class="mt-3 space-y-2.5">
    <h2 class="text-2xl font-semibold tracking-tight text-foreground">
      <%= link_to post.title, path, class: "transition-colors hover:text-primary" %>
    </h2>
    <p class="max-w-3xl text-[0.97rem] leading-7 text-muted-foreground"><%= post.excerpt %></p>
  </div>
</article>
