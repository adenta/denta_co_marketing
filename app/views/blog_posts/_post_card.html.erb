<article class="border-t py-6 first:border-t-0">
  <div class="space-y-1.5">
    <h2 class="text-[1.45rem] font-semibold tracking-tight text-foreground sm:text-[1.65rem]">
      <%= link_to post.title, path, class: "transition-colors hover:text-primary" %>
    </h2>
    <div class="flex flex-wrap items-center gap-2 text-sm text-muted-foreground">
      <time datetime="<%= post.published_on.iso8601 %>"><%= post.published_on.to_fs(:long) %></time>
      <% if post.draft? %>
        <span>&bull;</span>
        <span class="text-amber-900 dark:text-amber-200">Draft</span>
      <% end %>
    </div>
    <p class="max-w-3xl text-[0.98rem] leading-7 text-muted-foreground"><%= post.excerpt %></p>
  </div>
</article>
