<article class="rounded-3xl border border-border/70 bg-card/80 p-6 shadow-sm shadow-black/5">
  <div class="flex flex-wrap items-center gap-3 text-sm text-muted-foreground">
    <time datetime="<%= post.published_on.iso8601 %>"><%= post.published_on.to_fs(:long) %></time>
    <span>&middot;</span>
    <span><%= pluralize(post.reading_time_minutes, "minute") %> read</span>
    <% if post.draft? %>
      <span class="rounded-full bg-amber-100 px-2.5 py-1 text-xs font-semibold tracking-[0.14em] text-amber-900 uppercase">Draft</span>
    <% end %>
  </div>

  <div class="mt-4 space-y-3">
    <h2 class="text-2xl font-semibold tracking-tight text-foreground">
      <%= link_to post.title, path, class: "hover:text-primary" %>
    </h2>
    <p class="max-w-3xl text-base leading-7 text-muted-foreground"><%= post.excerpt %></p>
  </div>

  <% if post.tags.any? %>
    <div class="mt-5 flex flex-wrap gap-2">
      <% post.tags.each do |tag| %>
        <span class="rounded-full border border-border bg-background px-3 py-1 text-xs font-medium tracking-[0.12em] text-muted-foreground uppercase"><%= tag %></span>
      <% end %>
    </div>
  <% end %>
</article>
