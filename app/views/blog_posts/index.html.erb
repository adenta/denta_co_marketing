<% content_for :head do %>
  <%= stylesheet_link_tag "blog", "data-turbo-track": "reload" %>
<% end %>

<section class="mx-auto max-w-6xl px-4 py-8 sm:px-6 sm:py-10 lg:px-8">
  <div class="mb-6">
    <h1 class="text-3xl font-semibold tracking-tight text-foreground">Writing</h1>
  </div>

  <div>
    <% @posts.each do |post| %>
      <%= render "post_card", post:, path: post.path %>
    <% end %>

    <% if @posts.empty? %>
      <div class="border-t border-dashed border-border/80 py-8 text-muted-foreground">
        Add markdown files to publish the first post.
      </div>
    <% end %>

    <div class="border-t border-border/70 pt-8">
      <%= render "subscribe_card" %>
    </div>
  </div>
</section>
