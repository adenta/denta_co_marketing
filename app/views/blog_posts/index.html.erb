<% content_for :title, "Blog | Denta Co Marketing" %>
<% content_for :head do %>
  <%= stylesheet_link_tag "blog", "data-turbo-track": "reload" %>
<% end %>

<section class="relative overflow-hidden border-b border-border/70 bg-linear-to-br from-slate-50 via-white to-emerald-50">
  <div class="mx-auto max-w-6xl px-4 py-20 sm:px-6 lg:px-8">
    <div class="max-w-3xl space-y-6">
      <p class="text-sm font-semibold tracking-[0.28em] text-muted-foreground uppercase">Denta Co Journal</p>
      <h1 class="text-4xl font-semibold tracking-tight text-foreground sm:text-5xl">
        Marketing lessons for dental practices that want more high-intent patients.
      </h1>
      <p class="text-lg leading-8 text-muted-foreground">
        Essays, experiments, and practical notes on dental growth, conversion, and how modern practice websites should actually perform.
      </p>
    </div>
  </div>
</section>

<section class="mx-auto max-w-6xl px-4 py-12 sm:px-6 lg:px-8">
  <div class="space-y-6">
    <% @posts.each do |post| %>
      <%= render "post_card", post:, path: blog_post_path(post.slug) %>
    <% end %>

    <% if @posts.empty? %>
      <div class="rounded-3xl border border-dashed border-border p-10 text-center text-muted-foreground">
        Add markdown files to <code>content/blog</code> to publish the first post.
      </div>
    <% end %>
  </div>
</section>
