<% content_for :title, "Writing | Andrew Denta" %>
<% provide :meta_description, "Essays, notes, and practical writing on AI, software, systems, and the operational edges where products either hold up or fail." %>
<% content_for :head do %>
  <%= stylesheet_link_tag "blog", "data-turbo-track": "reload" %>
<% end %>

<section class="blog-grid-shell border-b border-[#237671]/10">
  <div aria-hidden="true" class="blog-square-cluster blog-square-cluster--top-left">
    <span></span>
    <span></span>
  </div>
  <div aria-hidden="true" class="blog-square-cluster blog-square-cluster--top-right">
    <span></span>
    <span></span>
  </div>

  <div class="mx-auto max-w-6xl px-4 py-24 sm:px-6 lg:px-8">
    <div class="max-w-3xl space-y-6">
      <p class="text-sm font-semibold tracking-[0.28em] text-[#237671] uppercase">Andrew Denta</p>
      <h1 class="text-4xl font-semibold tracking-tight text-foreground sm:text-5xl">
        Writing on AI, software, and the systems that make ambitious work feel calmer.
      </h1>
      <p class="text-lg leading-8 text-[#4f5b57]">
        Essays, experiments, and practical notes on product judgment, operational friction, growth, and the workflows that reveal where software holds up.
      </p>
    </div>
  </div>
</section>

<section class="relative mx-auto max-w-6xl px-4 py-12 sm:px-6 lg:px-8">
  <div aria-hidden="true" class="blog-square-cluster blog-square-cluster--bottom-right">
    <span></span>
    <span></span>
    <span></span>
    <span></span>
    <span></span>
  </div>

  <div class="space-y-6">
    <% @posts.each do |post| %>
      <%= render "post_card", post:, path: blog_post_path(post.slug) %>
    <% end %>

    <% if @posts.empty? %>
      <div class="blog-surface-card rounded-3xl border border-dashed p-10 text-center text-muted-foreground">
        Add markdown files to <code>content/blog</code> to publish the first post.
      </div>
    <% end %>
  </div>
</section>
