<% content_for :head do %>
  <%= stylesheet_link_tag "blog", "data-turbo-track": "reload" %>
<% end %>

<section class="mx-auto max-w-5xl px-4 py-8 sm:px-6 sm:py-10 lg:px-8">
  <div class="blog-post-hero-simple max-w-4xl mb-8 sm:mb-10">
    <%= link_to @page_content[:home_link_label], root_path, class: "blog-post-hero-simple__back" %>
    <div class="blog-post-hero-simple__title-block">
      <p class="text-sm font-semibold tracking-[0.28em] text-primary uppercase"><%= @page_content[:eyebrow] %></p>
      <h1 class="max-w-4xl text-[2.7rem] font-semibold tracking-tight text-foreground sm:text-[3rem] sm:leading-[1.05]">
        <%= @page_content[:title] %>
      </h1>
      <p class="max-w-3xl text-[1rem] leading-7 text-[#475569] dark:text-[#9eabb8]">
        <%= @page_content[:body] %>
      </p>
    </div>
  </div>

  <div class="blog-index-list">
    <% @posts.each do |post| %>
      <%= render "post_card", post:, path: post.path %>
    <% end %>

    <% if @posts.empty? %>
      <div class="border-t border-dashed border-border/80 py-8 text-muted-foreground">
        <%= @page_content[:empty_state] %> <code>content/blog</code> to publish the first post.
      </div>
    <% end %>

    <div class="border-t border-border/70 pt-8">
      <%= render "subscribe_card" %>
    </div>
  </div>
</section>
