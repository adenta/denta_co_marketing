<% favicon = favicon_paths %>
{
  "name": "<%= I18n.t("site.manifest.name", default: "DentaCoMarketing") %>",
  "icons": [
    {
      "src": "<%= favicon.fetch(:png) %>",
      "type": "image/png",
      "sizes": "512x512"
    },
    {
      "src": "<%= favicon.fetch(:png) %>",
      "type": "image/png",
      "sizes": "512x512",
      "purpose": "maskable"
    }
  ],
  "start_url": "/",
  "display": "standalone",
  "scope": "/",
  "description": "<%= I18n.t("site.manifest.description", default: "DentaCoMarketing.") %>",
  "theme_color": "<%= I18n.t("site.manifest.theme_color", default: "red") %>",
  "background_color": "<%= I18n.t("site.manifest.background_color", default: "red") %>"
}
