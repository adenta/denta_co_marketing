<!DOCTYPE html>
<html lang="en">
  <head>
    <% favicon = favicon_paths %>
    <% default_title = I18n.t("site.meta.default_title", default: "Andrew Denta") %>
    <% application_name = I18n.t("site.meta.application_name", default: default_title) %>
    <% page_meta = resolved_page_meta %>
    <% page_title = page_meta.fetch(:title) %>
    <% meta_description = page_meta.fetch(:description) %>
    <% canonical_url = page_meta.fetch(:canonical_url) %>
    <% meta_image_url = page_meta.fetch(:image_url) %>
    <title><%= page_title %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="color-scheme" content="light dark">
    <% if meta_description.present? %>
      <meta name="description" content="<%= meta_description %>">
    <% end %>
    <meta name="author" content="<%= application_name %>">
    <link rel="canonical" href="<%= canonical_url %>">
    <link rel="alternate" type="application/atom+xml" title="<%= "#{application_name} feed" %>" href="<%= absolute_page_url(feed_path(format: :xml)) %>">
    <meta property="og:locale" content="en_US">
    <meta property="og:site_name" content="<%= application_name %>">
    <meta property="og:type" content="<%= page_meta.fetch(:og_type) %>">
    <meta property="og:title" content="<%= page_title %>">
    <% if meta_description.present? %>
      <meta property="og:description" content="<%= meta_description %>">
    <% end %>
    <meta property="og:url" content="<%= canonical_url %>">
    <meta property="og:image" content="<%= meta_image_url %>">
    <meta name="twitter:card" content="<%= page_meta.fetch(:twitter_card) %>">
    <meta name="twitter:title" content="<%= page_title %>">
    <% if meta_description.present? %>
      <meta name="twitter:description" content="<%= meta_description %>">
    <% end %>
    <meta name="twitter:image" content="<%= meta_image_url %>">
    <% if page_meta[:og_type] == "article" && page_meta[:published_time].present? %>
      <meta property="article:published_time" content="<%= page_meta[:published_time].iso8601 %>">
    <% end %>
    <% if page_meta[:og_type] == "article" && page_meta[:author].present? %>
      <meta property="article:author" content="<%= page_meta[:author] %>">
    <% end %>
    <% page_meta.fetch(:structured_data).each do |structured_data| %>
      <script type="application/ld+json"><%= raw(json_escape(JSON.generate(structured_data))) %></script>
    <% end %>
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="<%= application_name %>">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= action_cable_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="<%= favicon.fetch(:png) %>" type="image/png">
    <link rel="icon" href="<%= favicon.fetch(:svg) %>" type="image/svg+xml">
    <link rel="apple-touch-icon" href="<%= favicon.fetch(:png) %>">

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= vite_client_tag %>
    <%= vite_react_refresh_tag %>
    <%= vite_typescript_tag "application" %>
    <%= javascript_tag nonce: true do %>
      (() => {
        const storageKey = "denta-theme";
        let storedPreference = null;

        try {
          storedPreference = window.localStorage.getItem(storageKey);
        } catch (_error) {
          storedPreference = null;
        }

        const prefersDarkMode = window.matchMedia("(prefers-color-scheme: dark)").matches;
        const resolvedTheme = storedPreference === "light" || storedPreference === "dark"
          ? storedPreference
          : prefersDarkMode
            ? "dark"
            : "light";
        const root = document.documentElement;

        root.classList.toggle("dark", resolvedTheme === "dark");
        root.dataset.theme = resolvedTheme;
        root.style.colorScheme = resolvedTheme;
      })();
    <% end %>

  </head>

  <body>
    <% developer_sign_in_enabled = Rails.env.development? || Rails.env.test? %>
    <% if authenticated? || developer_sign_in_enabled %>
      <%= turbo_mount(
        "navigation/AuthControls",
        props: {
          authenticated: authenticated?,
          analytics_path: "/blazer",
          developer_sign_in_path: api_v1_developer_session_path,
          developer_sign_in_enabled: developer_sign_in_enabled,
          home_path: root_path,
          logout_path: api_v1_session_path,
        },
      ) %>
    <% end %>
    <main>
      <%= yield %>
    </main>
    <%= turbo_mount("utils/ToastContainer", props: FlashBlueprint.render_as_hash(flash).compact) %>
  </body>
</html>
