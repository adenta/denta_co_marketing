<% content_for :head do %>
  <%= stylesheet_link_tag "blog", "data-turbo-track": "reload" %>
<% end %>

<% back_path = writing_path %>
<% back_label = "Back to writing" %>

<section class="mx-auto max-w-6xl px-4 py-8 sm:px-6 sm:py-10 lg:px-8">
  <div class="max-w-3xl">
    <div class="mb-8 space-y-4 sm:mb-10">
      <%= link_to back_label, back_path, class: "inline-flex text-sm text-muted-foreground transition-colors hover:text-foreground" %>

      <div class="space-y-4">
        <h1 class="text-4xl font-semibold tracking-tight text-foreground sm:text-5xl"><%= @post.title %></h1>
        <div class="flex flex-wrap items-center gap-2 border-t pt-4 text-sm text-muted-foreground">
          <time datetime="<%= @post.published_on.iso8601 %>"><%= @post.published_on.to_fs(:long) %></time>
          <span>&bull;</span>
          <span><%= @post.author %></span>
          <% if @post.draft? %>
            <span>&bull;</span>
            <span class="text-amber-900 dark:text-amber-200">Draft preview</span>
          <% end %>
        </div>
        <p class="text-base leading-7 text-muted-foreground"><%= @post.excerpt %></p>
      </div>
    </div>

    <article class="blog-prose">
      <%= @post.html_body.html_safe %>
    </article>

    <% unless @post.project? %>
      <div class="mt-8">
        <%= render "writings/subscribe_card" %>
      </div>
    <% end %>
  </div>
</section>
